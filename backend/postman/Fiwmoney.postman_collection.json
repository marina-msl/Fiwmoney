  "item": [
    {
      "name": "auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var token = pm.response.headers.get(\"Authorization\");\r",
                  "if (token) {\r",
                  "    pm.environment.set(\"token\", token.replace(\"Bearer\", \"\"));\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"username\": \"your_username\",\r\n    \"password\": \"your_password\",\r\n    \"name\": \"Your Name\",\r\n    \"email\": \"your@email.com\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://www.localhost:8080/auth/register",
              "protocol": "http",
              "host": [
                "www",
                "localhost"
              ],
              "port": "8080",
              "path": [
                "auth",
                "register"
              ]
            }
          },
          "response": []
        },
